<script>
    $(document).ready(function () {
        var dataArr = [];

        var dataTable = $('#storeInfoTbl').DataTable({
            'destroy': true,
            'processing': true,
            'serverSide': true,
            'paging': false,
            'searching': false,
            'info': false,
            'scrollY': 400,
            'scrollCollapse': true,
            'serverMethod': 'get',
            'ajax': {
                'url': '/branch/LoadData',
            },
            'columns': [
                { data: 'locationname' },
                {
                    data: null,
                    'targets': 1,
                    'render': function (data, type, row, meta) {
                        return '<a href=' + data['googleaddress'] + '>' + data['locationaddress'] + '</a>';
                    }
                },
            ]
        });

        $(document).on('click', "#registerBtn", function () {
            var locationname = $('#locationname').val();
            var locationaddress = $('#locationaddress').val();
            var googleaddress = $('#googleaddress').val();

            var message = "";

            if (locationname == "") { locationname += "Location Name " }
            if (locationaddress == "") { locationaddress += "Location Address " }
            if (googleaddress == "") { googleaddress += "Google Address " }

            if (message != "") { alert("Must fill-up " + message + " field!") }
            else {
                dataArr.push({
                    'locationname': locationname,
                    'locationaddress': locationaddress,
                    'googleaddress': googleaddress
                });

                var data = JSON.stringify(dataArr, null, 2);

                $.ajax({
                    type: "POST",
                    url: "http://localhost:3000/branch/register",
                    data: {
                        locationname: locationname,
                        data: data
                    },
                    success: function (result) {
                        alert("Data Saved!");
                        $('#storeInfoTbl').DataTable().ajax.reload();
                        dataArr = [];
                    },
                    error: function (result) {
                        alert('error: ' + result.data);
                    }
                });
            }

        });

    });
</script>