<script>
    $(document).ready(function () {
        var dataArr = [];

        let position = '<%- position%>';
        if (position != 'CREATOR') {
            $("#masters").toggle(0, function () { });
        }

        var dataTable = $('#storeInfoTbl').DataTable({
            'destroy': true,
            'processing': true,
            'serverSide': true,
            'paging': false,
            'searching': false,
            'info': false,
            'scrollY': 400,
            'scrollCollapse': true,
            'serverMethod': 'get',
            'ajax': {
                'url': '/request/LoadData',
            },
            'columns': [
                { data: 'date' },
                { data: 'ticketnum' },
                { data: 'personel' },
                { data: 'location' },
                { data: 'budget' },
                { data: 'status' },
            ]
        });

        $(document).on('click', "#registerBtn", function () {
            var ticketnum = $('#ticketnum').val();
            var personel = $('#personel').val();
            var location = $('#location').val();
            var budget = $('#budget').val();
            var date = (document).querySelector("#date").textContent;

            console.log(date);

            var message = "";

            if (ticketnum == "") { message += "Ticket Number " }
            if (personel == "") { message += "Personel " }
            if (location == "") { message += "Location " }
            if (budget == "") { message += "Budget " }

            if (message != "") { warning("Warning!", "Must fill-up " + message + " field!") }
            else {
                dataArr.push({
                    'date': date,
                    'ticketnum': ticketnum,
                    'personel': personel,
                    'location': location,
                    'budget': budget,
                    'status': 'PENDING'
                });

                var data = JSON.stringify(dataArr, null, 2);

                $.ajax({
                    type: "POST",
                    url: "/request/register",
                    data: {
                        personel: personel,
                        date: date,
                        data: data
                    },
                    success: function (result) {
                        success('Request Sent!', 'Budget request for pending!')
                        $('#storeInfoTbl').DataTable().ajax.reload();
                        dataArr = [];
                    },
                    error: function (result) {
                        error(result.data);
                    }
                });
            }

        });

        $.ajax({
            type: "GET",
            url: "/personel/personels",
            success: function (result) {
                console.log(result.data);

                $.each(result.data, function (key, item) {
                    var options = new Option(item, item);
                    $(options).html(item);
                    $('#personel').append(options);
                });
            },
            error: function (result) {
                alert('error: ' + result.data);
            }
        });

        $.ajax({
            type: "GET",
            url: "/personel/locations",
            success: function (result) {
                console.log(result.data);

                $.each(result.data, function (key, item) {
                    var options = new Option(item, item);
                    $(options).html(item);
                    $('#location').append(options);
                });
            },
            error: function (result) {
                alert('error: ' + result.data);
            }
        });

    });
</script>