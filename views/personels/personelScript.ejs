<script>
    $(document).ready(function () {
        var dataArr = [];

        $.ajax({
            type: "GET",
            url: "http://localhost:3000/personel/locations",
            success: function (result) {
                console.log(result.data);

                $.each(result.data, function (key, item) {
                    var options = new Option(item, item);
                    $(options).html(item);
                    $('#assignedlocation').append(options);
                });
            },
            error: function (result) {
                alert('error: ' + result.data);
            }
        });

        $.ajax({
            type: "GET",
            url: "http://localhost:3000/personel/positions",
            success: function (result) {
                console.log(result.data);

                $.each(result.data, function (key, item) {
                    var options = new Option(item, item);
                    $(options).html(item);
                    $('#position').append(options);
                });
            },
            error: function (result) {
                alert('error: ' + result.data);
            }
        });

        $.ajax({
            type: "GET",
            url: "http://localhost:3000/personel/personels",
            success: function (result) {
                console.log(result.data);

                $.each(result.data, function (key, item) {
                    var options = new Option(item, item);
                    $(options).html(item);
                    $('#personel').append(options);
                });
            },
            error: function (result) {
                alert('error: ' + result.data);
            }
        });

        var dataTable = $('#storeInfoTbl').DataTable({
            'destroy': true,
            'processing': true,
            'serverSide': true,
            'paging': false,
            'searching': false,
            'info': false,
            'scrollY': 400,
            'scrollCollapse': true,
            'serverMethod': 'GET',
            'ajax': {
                'url': '/personel/LoadData',
            },
            'columns': [
                { data: 'idnumber' },
                { data: 'fullname' },
                { data: 'position' },
                { data: 'assignedlocation' }
            ]
        });

        $(document).on('click', "#registerBtn", function () {
            var idnumber = $('#idnumber').val();
            var fullname = $('#fullname').val();
            var position = $('#position').val();
            var assignedlocation = $('#assignedlocation').val();

            var message = "";

            if (idnumber == "") { idnumber += "ID " }
            if (fullname == "") { fullname += "Fullname " }
            if (position == "") { position += "Position " }
            if (assignedlocation == "-" || assignedlocation == "") { assignedlocation += "Assigned Location " }

            if (message != "") { alert("Must fill-up " + message + " field!") }
            else {
                dataArr.push({
                    'idnumber': idnumber,
                    'fullname': fullname,
                    'position': position,
                    'assignedlocation': assignedlocation
                });

                var data = JSON.stringify(dataArr, null, 2);

                $.ajax({
                    type: "POST",
                    url: "http://localhost:3000/personel/register",
                    data: {
                        idnumber: idnumber,
                        fullname: fullname,
                        data: data
                    },
                    success: function (result) {
                        alert("Data Saved!");
                        $('#storeInfoTbl').DataTable().ajax.reload();
                        dataArr = [];
                    },
                    error: function (result) {
                        alert('error: ' + result.data);
                    }
                });
            }

        });

    });
</script>