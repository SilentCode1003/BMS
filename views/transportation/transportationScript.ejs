<script>
        $(document).ready(function () {
            var dataArr = [];
    
            var dataTable = $('#storeInfoTbl').DataTable({
                'destroy': true,
                'processing': true,
                'serverSide': true,
                'paging': false,
                'searching': false,
                'info': false,
                'scrollY': 400,
                'scrollCollapse': true,
                'serverMethod': 'get',
                'ajax': {
                    'url': '/transportation/LoadData',
                },
                'columns': [
                    { data: 'transportationcode' },
                    { data: 'transportationname' },
                    { data: 'createdby' },
                    { data: 'createddate' },
                ]
            });
    
            $(document).on('click', "#registerBtn", function () {
                var transportationcode = $('#transportationcode').val();
                var transportationname = $('#transportationname').val();
                var date = (document).querySelector("#date").textContent;

                console.log(date);
    
                var message = "";
    
                if (transportationcode == "") { transportationcode += "Transportation Code " }
                if (transportationname == "") { transportationname += "Transportation Name " }
                   
                if (message != "") { alert("Must fill-up " + message + " field!") }
                else {
                    dataArr.push({
                        'transportationcode': transportationcode,
                        'transportationname': transportationname,
                        'createdby': 'Creator',
                        'createddate': date
                    });
    
                    var data = JSON.stringify(dataArr, null, 2);
    
                    $.ajax({
                        type: "POST",
                        url: "/transportation/register",
                        data: {
                            transportationname: transportationname,
                            data: data
                        },
                        success: function (result) {
                            alert("Data Saved!");
                            $('#storeInfoTbl').DataTable().ajax.reload();
                            dataArr = [];
                        },
                        error: function (result) {
                            alert('error: ' + result.data);
                        }
                    });
                }
    
            });
    
        });
    </script>