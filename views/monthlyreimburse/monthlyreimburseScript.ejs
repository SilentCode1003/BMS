<script>
    $(document).ready(function () {
        var table;
        var dataTable;

        let position = '<%- position%>';
        if (position != 'CREATOR') {
            $("#masters").toggle(0, function () { });
        }

        $(document).on('click', "#serachBtn", function () {
            var personel = $('#personel').val();

            console.log(personel);

            dataTable = $('#equipmentTbl').DataTable({
                'destroy': true,
                'processing': true,
                'serverSide': true,
                'paging': false,
                'searching': false,
                'info': false,
                'serverMethod': 'POST',
                'ajax': {
                    'url': '/monthlyreimburse/LoadData',
                    'data': {
                        personel: personel
                    }
                },
                'columns': [
                    { data: 'date' },
                    { data: 'personel' },
                    { data: 'totalbudget' },
                    { data: 'totalreimburse' },
                    { data: 'remaining' },
                ]
            });
        });

        // Get the modal
        var modal = document.getElementById("reportModal");

        // Get the button that opens the modal
        // var btn = document.getElementById("reportBtn");

        // Get the <span> element that closes the modal
        var span = document.getElementsByClassName("close")[0];

        // When the user clicks the button, open the modal 
        // btn.onclick = function () {
        //     modal.style.display = "block";

        //     //Load active data
        //     table = $('#modalNetworkDeviceTbl').DataTable({
        //         'destroy': true,
        //         'processing': true,
        //         'serverSide': true,
        //         'paging': false,
        //         'searching': false,
        //         'info': false,
        //         'scrollY': 380,
        //         'scrollCollapse': false,
        //         'serverMethod': 'POST',
        //         'ajax': {
        //             'url': '/reimbursementsummary/retrieveFile',
        //             'data': {
        //                 filename: filename
        //             }
        //         },
        //         'columns': [
        //             { data: 'Ticket' },
        //             { data: 'Destination' },
        //             { data: 'Type' },
        //             { data: 'Cost' }
        //         ]
        //     });
        // }

        // When the user clicks on <span> (x), close the modal
        span.onclick = function () {
            modal.style.display = "none";
        }

        // When the user clicks anywhere outside of the modal, close it
        window.onclick = function (event) {
            if (event.target == modal) {
                modal.style.display = "none";
            }
        }

        $(document).on('click', "#printBtn", function () {
            var printContents = document.getElementById('printArea').innerHTML;
            var originalContents = document.body.innerHTML;
            document.body.innerHTML = printContents;
            window.print();
            document.body.innerHTML = originalContents;
            location.reload();
        });

        $('#equipmentTbl tbody').on('click', 'tr', function () {

            var date;
            var personel;
            var position;
            var budget;
            var cost = 0;
            var petteycash;
            var balance = 0;
            var totalbudget = 0;
            var reason = "";


            var data = dataTable.row(this).data();
            console.log(data);

            var subfolder = data.date;
            var personel = data.personel;

            modal.style.display = "block";

            var t = $('#modalNetworkDeviceTbl').DataTable({
                'destroy': true,
                'paging': false,
                'searching': false,
                'info': false,
                'scrollCollapse': true,
            });

            $.ajax({
                type: "POST",
                url: "/personel/getPersonel",
                data: {
                    personel: personel
                },
                success: function (result) {
                    console.log(`getPersonel: ${JSON.stringify(result.data)}}`)
                    $.each(result.data, function (key, item) {
                        document.getElementById('IDTxt').innerText = item.id;
                        document.getElementById('personelTxt').innerText = item.id;
                        document.getElementById('positionTxt').innerText = item.position;
                        document.getElementById('locationTxt').innerText = item.location;
                    });
                },
                error: function (result) {
                    error(result.msg);
                }
            });

            $.ajax({
                type: "POST",
                url: "/monthlyreimburse/GetMonthlyData",
                data: {
                    personel: personel,
                    subfolder: subfolder,
                },
                success: function (result) {
                    console.log(`GetMonthlyData: ${JSON.stringify(result.data)}}}`)
                    $.each(result.data, function (key, item) {
                        // (12345.67).toFixed(2).replace(/\d(?=(\d{3})+\.)/g, '$&,'); 
                        // amount.toLocaleString('en-US', { style: 'currency', currency: 'USD' });
                        var totalbudget = (item.totalbudget).toFixed(2).replace(/\d(?=(\d{3})+\.)/g, '$&,');
                        var totalcost = (item.totalcost).toFixed(2).replace(/\d(?=(\d{3})+\.)/g, '$&,');
                        var balance = (item.balance).toFixed(2).replace(/\d(?=(\d{3})+\.)/g, '$&,');

                        document.getElementById('modalTotalBudget').innerText = `₱ ${totalbudget}`;
                        document.getElementById('modalCost').innerText = `₱ ${totalcost}`;
                        document.getElementById('modalBalance').innerText = `₱ ${balance}`;
                    });
                },
                error: function (result) {
                    error(result.msg);
                }
            });

            $.ajax({
                type: "POST",
                url: "/monthlyreimburse/LoadMonthlyFiles",
                data: {
                    personel: personel,
                    subfolder: subfolder,
                },
                success: function (result) {
                    t.clear().draw();
                    $.each(result.data, function (key, item) {
                        t.row.add([item.date, item.personel, item.pettycash, item.budget, item.totalbudget, item.totalcost, item.balance]).draw(false);
                    })

                    // totalbudget = parseFloat(budget) + parseFloat(petteycash);
                    // balance = parseFloat(totalbudget) - parseFloat(cost);

                    // document.getElementById('reasonTxt').innerText = "\n" + reason;
                    // document.getElementById('personelTxt').innerText = personel;
                    // document.getElementById('positionTxt').innerText = position;
                    // document.getElementById('dateTxt').innerText = date;
                    // document.getElementById('modalPettyCash').innerText = "₱ " + petteycash;
                    // document.getElementById('modalBudget').innerText = "₱ " + budget;
                    // document.getElementById('modalCost').innerText = "₱ " + cost;
                    // document.getElementById('modalTotalBudget').innerText = "₱ " + totalbudget;
                    // document.getElementById('modalBalance').innerText = "₱ " + balance;
                },
                error: function (result) {
                    alert('error: ' + result.data);
                }
            });
        });

        $.ajax({
            type: "GET",
            url: "/personel/personels",
            success: function (result) {
                console.log(result.data);

                $.each(result.data, function (key, item) {
                    var options = new Option(item, item);
                    $(options).html(item);
                    $('#personel').append(options);
                });
            },
            error: function (result) {
                alert('error: ' + result.data);
            }
        });
    });
</script>